{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2025-08-14",
  "main": "src/index.js",
  "name": "chrome-web-store-mirror",
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "workers_dev": false,
}
